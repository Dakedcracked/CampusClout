# Copy to backend/.env and fill in values
APP_NAME=CampusClout
DEBUG=true

DATABASE_URL=postgresql+asyncpg://campusclout:campusclout@localhost:5432/campusclout

REDIS_URL=redis://localhost:6379

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth: leave ALLOWED_EMAIL_DOMAINS as [] to allow any .edu domain
# To restrict: ALLOWED_EMAIL_DOMAINS=university.edu,college.edu
ALLOWED_EMAIL_DOMAINS=[]
REQUIRE_EDU_EMAIL=true

# Token Economy
SIGNUP_BONUS_TOKENS=100
MAX_INVEST_PERCENTAGE=0.5
