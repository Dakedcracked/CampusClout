# =====================================================================
# CampusClout Frontend — Environment Variables
# Copy this to .env.local for local dev, or set these in Vercel dashboard
# =====================================================================

# ----- Backend API URL -----
# IMPORTANT: Set this to your Railway backend URL — no trailing slash
# This is used by Next.js server-side rewrites to proxy /api/* calls to Railway
# Without this, Next.js will fall back to http://localhost:8000 (unreachable on Vercel!)
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# ----- Local development default -----
# For local dev, leave NEXT_PUBLIC_API_URL unset or set to:
# NEXT_PUBLIC_API_URL=http://localhost:8000
