# =====================================================================
# CampusClout Backend — Environment Variables
# Copy this to .env for local dev, or set these in Railway for production
# =====================================================================

# ----- App -----
APP_NAME=CampusClout
APP_VERSION=0.1.0
DEBUG=false
# IMPORTANT: Set to "production" on Railway so cookies use samesite=none
ENVIRONMENT=production

# ----- Frontend URL (your Vercel domain) -----
# IMPORTANT: Set this to your actual Vercel URL — no trailing slash
# This is added to CORS_ORIGINS automatically
FRONTEND_URL=https://your-app.vercel.app

# ----- CORS (comma-separated, or JSON array) -----
# Add all frontend origins here (Vercel preview URLs, custom domain, etc.)
CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ----- Database (Railway auto-sets DATABASE_URL for Postgres plugin) -----
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ----- Redis (Railway auto-sets REDIS_URL for Redis plugin) -----
REDIS_URL=redis://default:password@host:6379

# ----- JWT (CHANGE THIS — use a long random secret in production!) -----
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Ollama AI (if self-hosting, set to your Ollama instance URL) -----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
VISION_MODEL=llama3.2-vision
VISION_MODEL_FALLBACK=llava
VISION_TIMEOUT=20

# ----- Email (Mailgun) -----
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SENDER_EMAIL=noreply@campusclout.app

# ----- College/University Email Enforcement -----
REQUIRE_EDU_EMAIL=false
ALLOWED_EMAIL_DOMAINS=

# ----- Economy -----
SIGNUP_BONUS_TOKENS=100
MAX_INVEST_PERCENTAGE=0.5
